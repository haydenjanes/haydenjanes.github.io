{
  "name": "just-code/just-contact-backend",
  "type": "library",
  "description": "just a backend to receive form data from HTTP forms",
  "keywords": ["contact form", "CORS"],
  "homepage": "https://gitlab.com/just-code/just_contact_backend",
  "license": "MIT",
  "authors": [{
      "name": "Adam Furmanczuk",
      "email": "adam@furmanczuk.eu"
    },
    {
      "name": "Hung Thai Nguyen",
      "email": "nthung.vlvn@gmail.com"
    }
  ],
  "require": {
    "curl/curl": "2.3.*",
    "phpmailer/phpmailer": "~6.1",
    "symfony/http-foundation": "^5.0.7",
    "php": ">=5.5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^7",
    "illuminate/http": "^7"
  },
  "autoload": {
    "psr-4": {
      "JustCode\\JustContactBackend\\": "src/"
